<%- include('partials/header', { extraCss: null }) %>

    <div class="auth-container" style="min-height: 80vh; display: flex; align-items: center; justify-content: center;">
        <div class="auth-card" style="border-top: 5px solid #ef4444; width: 100%; max-width: 400px; padding: 2.5rem;">
            <div class="auth-header text-center">
                <div style="font-size: 2.5rem; color: #ef4444; margin-bottom: 0.5rem;"><i class="fas fa-lock"></i></div>
                <h1 style="font-size: 1.5rem; margin-bottom: 0.5rem;">Admin Portal</h1>
                <p>Restricted Access - Staff Only</p>
                <% if(error) { %>
                    <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #f87171; padding: 0.75rem; border-radius: 8px; margin-top: 1rem; font-size: 0.85rem;">
                        <i class="fas fa-exclamation-circle"></i> <%= error %>
                    </div>
                <% } %>
            </div>
            <form action="/admin/login" method="POST" class="auth-form" style="margin-top: 1.5rem;">
                <div class="form-group">
                    <label for="email">Admin Email</label>
                    <input type="email" id="email" name="email" class="form-input" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" class="form-input" required>
                </div>
                <button type="submit" class="btn-hero-primary w-full" style="background: #ef4444; color: white;">Access Dashboard</button>
            </form>
            <div class="auth-footer text-center" style="margin-top: 1.5rem;">
                <p><a href="/" style="color: #94a3b8; text-decoration: none;"><i class="fas fa-arrow-left"></i> Return to Main Site</a></p>
            </div>
        </div>
    </div>

<%- include('partials/footer') %>
