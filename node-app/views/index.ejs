<%- include('partials/header') %>

    <!-- Hero Section -->
    <section class="hero" id="hero">
        <div class="hero-bg">
            <div class="hero-blob blob-1"></div>
            <div class="hero-blob blob-2"></div>
            <div class="hero-blob blob-3"></div>
        </div>
        <div class="hero-container">
            <div class="hero-badge">
                <span class="badge-dot"></span>
                Monthly Draw Now Open — ₹42,800 Prize Pool
            </div>
            <h1 class="hero-title">
                Play Your Game.<br>
                <span class="gradient-text">Change Lives.</span><br>
                Win Big.
            </h1>
            <p class="hero-subtitle">The subscription platform where your golf scores enter you into monthly prize draws — and every pound supports a cause you believe in.</p>
            <div class="hero-cta">
                <a href="/auth/signup" class="btn-hero-primary">
                    Start For Free <i class="fas fa-arrow-right"></i>
                </a>
                <a href="#how-it-works" class="btn-hero-ghost">
                    <i class="fas fa-play-circle"></i> See How It Works
                </a>
            </div>
            <div class="hero-stats">
                <div class="hero-stat">
                    <span class="stat-num">12,400+</span>
                    <span class="stat-label">Active Members</span>
                </div>
                <div class="stat-divider"></div>
                <div class="hero-stat">
                    <span class="stat-num">₹890K</span>
                    <span class="stat-label">Given to Charity</span>
                </div>
                <div class="stat-divider"></div>
                <div class="hero-stat">
                    <span class="stat-num">₹2.1M</span>
                    <span class="stat-label">Prizes Awarded</span>
                </div>
            </div>
        </div>
        <div class="hero-scroll-indicator">
            <div class="scroll-dot"></div>
        </div>
    </section>

    <!-- Social Proof Ticker -->
    <div class="ticker-bar">
        <div class="ticker-content">
            <span class="ticker-item"><i class="fas fa-trophy"></i> James M. won ₹8,400 last month</span>
            <span class="ticker-item"><i class="fas fa-heart"></i> ₹12,000 raised for MacMillan Cancer Support this week</span>
            <span class="ticker-item"><i class="fas fa-golf-ball-tee"></i> Sarah K. scored 38 — top of the leaderboard</span>
            <span class="ticker-item"><i class="fas fa-trophy"></i> Robert T. won ₹3,200 — 4-number match</span>
            <span class="ticker-item"><i class="fas fa-heart"></i> ₹6,800 donated to Age UK this month</span>
            <span class="ticker-item"><i class="fas fa-trophy"></i> James M. won ₹8,400 last month</span>
            <span class="ticker-item"><i class="fas fa-heart"></i> ₹12,000 raised for MacMillan Cancer Support this week</span>
            <span class="ticker-item"><i class="fas fa-golf-ball-tee"></i> Sarah K. scored 38 — top of the leaderboard</span>
        </div>
    </div>

    <!-- How It Works -->
    <section class="how-it-works" id="how-it-works">
        <div class="section-container">
            <div class="section-header">
                <span class="section-eyebrow">Simple & Rewarding</span>
                <h2 class="section-title">Three Steps to Playing With Purpose</h2>
                <p class="section-subtitle">No complicated rules. Just golf, generosity, and the chance to win.</p>
            </div>
            <div class="steps-grid">
                <div class="step-card" data-step="1">
                    <div class="step-number">01</div>
                    <div class="step-icon-wrap">
                        <i class="fas fa-user-plus step-icon"></i>
                    </div>
                    <h3 class="step-title">Subscribe & Choose Your Cause</h3>
                    <p class="step-desc">Pick a monthly or yearly plan. Select a charity from our directory — at least 10% of your fee goes directly to them.</p>
                    <div class="step-tags">
                        <span>Monthly ₹9.99</span>
                        <span>Yearly ₹89.99</span>
                    </div>
                </div>
                <div class="step-connector"><i class="fas fa-arrow-right"></i></div>
                <div class="step-card" data-step="2">
                    <div class="step-number">02</div>
                    <div class="step-icon-wrap">
                        <i class="fas fa-golf-ball-tee step-icon"></i>
                    </div>
                    <h3 class="step-title">Enter Your Golf Scores</h3>
                    <p class="step-desc">Log your last 5 Stableford scores (1–45). These become your draw numbers each month — the better you play, the better your odds.</p>
                    <div class="step-tags">
                        <span>Stableford Format</span>
                        <span>5 Scores Max</span>
                    </div>
                </div>
                <div class="step-connector"><i class="fas fa-arrow-right"></i></div>
                <div class="step-card" data-step="3">
                    <div class="step-number">03</div>
                    <div class="step-icon-wrap">
                        <i class="fas fa-trophy step-icon"></i>
                    </div>
                    <h3 class="step-title">Enter the Monthly Draw</h3>
                    <p class="step-desc">Your scores automatically enter you into the monthly prize draw. Match 3, 4, or 5 numbers to win a share of the prize pool.</p>
                    <div class="step-tags">
                        <span>3 Match — 25%</span>
                        <span>4 Match — 35%</span>
                        <span>5 Match — 40%</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Prize Pool Section -->
    <section class="prizes-section" id="prizes">
        <div class="section-container">
            <div class="section-header">
                <span class="section-eyebrow">This Month's Draw</span>
                <h2 class="section-title">The Prize Pool Is Growing</h2>
                <p class="section-subtitle">Every subscription contributes to the monthly prize pool. The jackpot rolls over if no 5-number winner is found.</p>
            </div>
            <div class="prize-display">
                <div class="jackpot-banner">
                    <div class="jackpot-label">🏆 Current Jackpot (5-Match)</div>
                    <div class="jackpot-amount" id="jackpotAmount">₹17,120</div>
                    <div class="jackpot-sub">40% of prize pool • Rolls over if unclaimed</div>
                </div>
                <div class="prize-tiers">
                    <div class="prize-tier tier-gold">
                        <div class="tier-icon">🥇</div>
                        <div class="tier-info">
                            <span class="tier-name">5-Number Match</span>
                            <span class="tier-pct">40% of Pool</span>
                        </div>
                        <div class="tier-amount">₹17,120</div>
                    </div>
                    <div class="prize-tier tier-silver">
                        <div class="tier-icon">🥈</div>
                        <div class="tier-info">
                            <span class="tier-name">4-Number Match</span>
                            <span class="tier-pct">35% of Pool</span>
                        </div>
                        <div class="tier-amount">₹14,980</div>
                    </div>
                    <div class="prize-tier tier-bronze">
                        <div class="tier-icon">🥉</div>
                        <div class="tier-info">
                            <span class="tier-name">3-Number Match</span>
                            <span class="tier-pct">25% of Pool</span>
                        </div>
                        <div class="tier-amount">₹10,700</div>
                    </div>
                </div>
                <div class="draw-countdown">
                    <div class="countdown-label">Next draw in</div>
                    <div class="countdown-timer" id="countdownTimer">
                        <div class="timer-block"><span id="days">08</span><small>days</small></div>
                        <div class="timer-block"><span id="hours">14</span><small>hrs</small></div>
                        <div class="timer-block"><span id="mins">32</span><small>min</small></div>
                        <div class="timer-block"><span id="secs">09</span><small>sec</small></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Charity Spotlight -->
    <section class="charity-spotlight">
        <div class="section-container">
            <div class="section-header">
                <span class="section-eyebrow">Make an Impact</span>
                <h2 class="section-title">Charities We Support</h2>
                <p class="section-subtitle">Choose a cause that moves you. Every subscription contributes directly to these organisations.</p>
            </div>
            <div class="charity-cards">
                <div class="charity-card featured">
                    <div class="charity-card-badge">⭐ Featured This Month</div>
                    <div class="charity-card-img" style="background: linear-gradient(135deg, #10b981, #059669);">
                        <i class="fas fa-ribbon charity-card-icon"></i>
                    </div>
                    <div class="charity-card-body">
                        <h3>Macmillan Cancer Support</h3>
                        <p>Providing specialist health care, information and financial support to people affected by cancer.</p>
                        <div class="charity-meta">
                            <span><i class="fas fa-users"></i> 840 supporters</span>
                            <span><i class="fas fa-pound-sign"></i> ₹124K raised</span>
                        </div>
                        <a href="/charities/1" class="btn-card">View Profile →</a>
                    </div>
                </div>
                <div class="charity-card">
                    <div class="charity-card-img" style="background: linear-gradient(135deg, #6366f1, #4f46e5);">
                        <i class="fas fa-child charity-card-icon"></i>
                    </div>
                    <div class="charity-card-body">
                        <h3>NSPCC</h3>
                        <p>Fighting for every childhood, protecting children from abuse and neglect across the UK.</p>
                        <div class="charity-meta">
                            <span><i class="fas fa-users"></i> 620 supporters</span>
                            <span><i class="fas fa-pound-sign"></i> ₹89K raised</span>
                        </div>
                        <a href="/charities/2" class="btn-card">View Profile →</a>
                    </div>
                </div>
                <div class="charity-card">
                    <div class="charity-card-img" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                        <i class="fas fa-paw charity-card-icon"></i>
                    </div>
                    <div class="charity-card-body">
                        <h3>RSPCA</h3>
                        <p>Preventing cruelty and promoting kindness to all animals — in England and Wales since 1824.</p>
                        <div class="charity-meta">
                            <span><i class="fas fa-users"></i> 510 supporters</span>
                            <span><i class="fas fa-pound-sign"></i> ₹67K raised</span>
                        </div>
                        <a href="/charities/3" class="btn-card">View Profile →</a>
                    </div>
                </div>
            </div>
            <div class="charity-cta-row">
                <a href="/charities" class="btn-outline-dark">Explore All Charities <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="testimonials">
        <div class="section-container">
            <div class="section-header">
                <span class="section-eyebrow">Real Members</span>
                <h2 class="section-title">What Our Community Says</h2>
            </div>
            <div class="testimonial-grid">
                <div class="testimonial-card">
                    <div class="testimonial-quote">"I've been playing golf for 20 years and this is the first platform that actually made me feel like my hobby matters. Won ₹3,200 in March!"</div>
                    <div class="testimonial-author">
                        <div class="author-avatar" style="background: #10b981;">JM</div>
                        <div class="author-info">
                            <span class="author-name">James Mitchell</span>
                            <span class="author-sub">Subscriber since 2023 · 4-Number Winner</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card featured-testimonial">
                    <div class="testimonial-quote">"The fact that 15% of my monthly fee goes to the NSPCC makes every round I play feel meaningful. The draw is just the icing on the cake."</div>
                    <div class="testimonial-author">
                        <div class="author-avatar" style="background: #6366f1;">SK</div>
                        <div class="author-info">
                            <span class="author-name">Sarah Keane</span>
                            <span class="author-sub">Subscriber since 2022 · Yearly Plan</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card">
                    <div class="testimonial-quote">"Entering scores takes 30 seconds and I'm automatically in the draw. Simple, brilliant, and I love following my charity's progress on the platform."</div>
                    <div class="testimonial-author">
                        <div class="author-avatar" style="background: #f59e0b;">RT</div>
                        <div class="author-info">
                            <span class="author-name">Robert Turner</span>
                            <span class="author-sub">Subscriber since 2024 · Monthly Plan</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="pricing">
        <div class="section-container">
            <div class="section-header">
                <span class="section-eyebrow">Simple Pricing</span>
                <h2 class="section-title">One Price. Unlimited Potential.</h2>
                <p class="section-subtitle">No hidden fees. Cancel anytime. Every penny counts toward prizes and charity.</p>
            </div>
            <div class="pricing-toggle-row">
                <span class="toggle-label">Monthly</span>
                <label class="toggle-switch">
                    <input type="checkbox" id="billingToggle">
                    <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label">Yearly <span class="save-badge">Save 25%</span></span>
            </div>
            <div class="pricing-cards">
                <div class="pricing-card" id="monthlyCard">
                    <div class="plan-name">Monthly</div>
                    <div class="plan-price"><span class="price-amount" id="monthlyPrice">₹9.99</span><span class="price-period">/month</span></div>
                    <div class="plan-desc">Perfect for casual players who want flexibility.</div>
                    <ul class="plan-features">
                        <li><i class="fas fa-check"></i> Monthly prize draw entry</li>
                        <li><i class="fas fa-check"></i> 5-score rolling tracker</li>
                        <li><i class="fas fa-check"></i> Charity selection & giving</li>
                        <li><i class="fas fa-check"></i> Draw results & history</li>
                        <li><i class="fas fa-check"></i> Mobile app access</li>
                    </ul>
                    <a href="/auth/signup?plan=monthly" class="btn-plan">Get Started</a>
                </div>
                <div class="pricing-card featured-plan" id="yearlyCard">
                    <div class="plan-badge">Best Value</div>
                    <div class="plan-name">Yearly</div>
                    <div class="plan-price"><span class="price-amount" id="yearlyPrice">₹7.50</span><span class="price-period">/month</span></div>
                    <div class="plan-sub" id="yearlyBilled">Billed ₹89.99/year</div>
                    <div class="plan-desc">For dedicated golfers committed to making impact.</div>
                    <ul class="plan-features">
                        <li><i class="fas fa-check"></i> Everything in Monthly</li>
                        <li><i class="fas fa-check"></i> Priority draw entry</li>
                        <li><i class="fas fa-check"></i> Increased charity contribution</li>
                        <li><i class="fas fa-check"></i> Exclusive member events</li>
                        <li><i class="fas fa-check"></i> Annual impact report</li>
                    </ul>
                    <a href="/auth/signup?plan=yearly" class="btn-plan-primary">Get Started</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta">
        <div class="cta-blob"></div>
        <div class="section-container">
            <h2 class="cta-title">Your Next Round Could Change Lives.<br><span class="gradient-text">And Win You Thousands.</span></h2>
            <p class="cta-subtitle">Join 12,400 golfers already playing with purpose. Set up takes under 2 minutes.</p>
            <a href="/auth/signup" class="btn-hero-primary large">
                Join GreenHeart Today <i class="fas fa-arrow-right"></i>
            </a>
            <p class="cta-note">No commitment. Cancel anytime. 10% always goes to your chosen charity.</p>
        </div>
    </section>

<%- include('partials/footer') %>
