<%- include('partials/header', { extraCss: null }) %>

    <!-- Sidebar Navigation -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <a href="/">
                <span class="logo-icon">⛳</span>
                <span class="logo-text">GreenHeart</span>
            </a>
        </div>
        <nav class="sidebar-nav">
            <a href="/dashboard" class="sidebar-link active">
                <i class="fas fa-th-large"></i>
                <span>Overview</span>
            </a>
            <a href="#scores" class="sidebar-link" onclick="showSection('scores', event)">
                <i class="fas fa-golf-ball-tee"></i>
                <span>My Scores</span>
            </a>
            <a href="#draws" class="sidebar-link" onclick="showSection('draws', event)">
                <i class="fas fa-random"></i>
                <span>Draw History</span>
            </a>
            <a href="#winnings" class="sidebar-link" onclick="showSection('winnings', event)">
                <i class="fas fa-trophy"></i>
                <span>Winnings</span>
            </a>
            <a href="#charity" class="sidebar-link" onclick="showSection('charity', event)">
                <i class="fas fa-heart"></i>
                <span>My Charity</span>
            </a>
            <a href="#subscription" class="sidebar-link" onclick="showSection('subscription', event)">
                <i class="fas fa-credit-card"></i>
                <span>Subscription</span>
            </a>
        </nav>
        <div class="sidebar-bottom">
            <div class="sidebar-user">
                <div class="user-avatar-sm"><%= user.first_name[0] %><%= user.last_name[0] %></div>
                <div class="user-info-sm">
                    <span class="user-name-sm"><%= user.first_name %> <%= user.last_name %></span>
                    <span class="user-plan-sm"><%= (user.plan || 'monthly').charAt(0).toUpperCase() + (user.plan || 'monthly').slice(1) %> Plan</span>
                </div>
            </div>
            <a href="/auth/logout" class="sidebar-logout">
                <i class="fas fa-sign-out-alt"></i>
                <span>Log Out</span>
            </a>
        </div>
    </aside>

    <!-- Mobile Header -->
    <header class="dash-mobile-header">
        <button class="sidebar-toggle-btn" id="sidebarToggle" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>
        <a href="/" class="nav-logo">
            <span class="logo-icon">⛳</span>
            <span class="logo-text">GreenHeart</span>
        </a>
        <div class="mobile-user-avatar"><%= user.first_name[0] %><%= user.last_name[0] %></div>
    </header>

    <!-- Main Content -->
    <main class="dashboard-main">
        
        <!-- Overview Section -->
        <section class="dash-section active" id="section-overview">
            <div class="dash-header">
                <div>
                    <h1 class="dash-title">Good morning, <%= user.first_name %> 👋</h1>
                    <p class="dash-subtitle">Next draw in <strong>8 days</strong> — your scores are entered</p>
                </div>
                <div class="dash-header-actions">
                    <button class="btn-dash-primary" onclick="showSection('scores', null); openScoreModal()">
                        <i class="fas fa-plus"></i> Enter Score
                    </button>
                </div>
            </div>

            <!-- Stat Cards -->
            <div class="stat-cards">
                <div class="stat-card">
                    <div class="stat-card-icon green">
                        <i class="fas fa-golf-ball-tee"></i>
                    </div>
                    <div class="stat-card-info">
                        <% let avgScore = scores.length ? (scores.reduce((sum, s) => sum + s.score, 0) / scores.length).toFixed(1) : 'N/A' %>
                        <span class="stat-card-value"><%= avgScore %></span>
                        <span class="stat-card-label">Avg. Stableford Score</span>
                    </div>
                    <div class="stat-card-trend neutral"><i class="fas fa-minus"></i> Since joining</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-icon purple">
                        <i class="fas fa-random"></i>
                    </div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">1</span>
                        <span class="stat-card-label">Draws Entered</span>
                    </div>
                    <div class="stat-card-trend neutral"><i class="fas fa-minus"></i> Since joining</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-icon gold">
                        <i class="fas fa-trophy"></i>
                    </div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">₹0</span>
                        <span class="stat-card-label">Total Winnings</span>
                    </div>
                    <div class="stat-card-trend neutral"><i class="fas fa-star"></i> 0 wins</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-icon red">
                        <i class="fas fa-heart"></i>
                    </div>
                    <div class="stat-card-info">
                        <span class="stat-card-value">₹<%= parseFloat(user.total_donated || 0).toFixed(2) %></span>
                        <span class="stat-card-label">Given to Charity</span>
                    </div>
                    <div class="stat-card-trend up"><i class="fas fa-arrow-up"></i> <%= charity ? charity.name : 'None' %></div>
                </div>
            </div>

            <!-- Two Column Layout -->
            <div class="dash-grid-2">

                <!-- Score Entry Card -->
                <div class="dash-card" id="scores-overview">
                    <div class="dash-card-header">
                        <h3><i class="fas fa-golf-ball-tee"></i> My Scores</h3>
                        <button class="btn-card-action" onclick="openScoreModal()">
                            <i class="fas fa-plus"></i> Add Score
                        </button>
                    </div>
                    <div class="scores-list" id="scoresList">
                        <% if(scores && scores.length > 0) { %>
                            <% scores.forEach((s, index) => { %>
                                <div class="score-item <%= index === 0 ? 'latest' : '' %>">
                                    <div class="score-num-badge"><%= s.score %></div>
                                    <div class="score-meta">
                                        <% let fDate = new Date(s.played_at).toLocaleDateString('en-GB') %>
                                        <span class="score-date"><%= fDate %> · <%= s.course_name || 'Unknown Course' %></span>
                                        <span class="score-status active">✓ In this month's draw</span>
                                    </div>
                                    <div class="score-actions">
                                        <button class="btn-score-edit" title="Edit" onclick="editScore(this, '<%= s.id %>')"><i class="fas fa-pen"></i></button>
                                        <button class="btn-score-del" title="Delete" onclick="deleteScoreBackend('<%= s.id %>')"><i class="fas fa-trash"></i></button>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="score-note">You don't have any scores yet. Add some to enter the draw!</p>
                        <% } %>
                    </div>
                    <p class="score-note"><i class="fas fa-info-circle"></i> You have <%= scores.length || 0 %> scores. Adding a new one will replace the oldest.</p>
                </div>

                <!-- Draw Status Card -->
                <div class="dash-card">
                    <div class="dash-card-header">
                        <h3><i class="fas fa-random"></i> This Month's Draw</h3>
                        <span class="dash-badge live">LIVE</span>
                    </div>
                    <div class="draw-status-display">
                        <div class="draw-numbers-row">
                            <% for(let i=0; i<5; i++) { %>
                                <div class="draw-num-ball"><%= scores[i] ? scores[i].score : '?' %></div>
                            <% } %>
                        </div>
                        <p class="draw-nums-label">Your draw numbers for <%= new Date().toLocaleString('default', { month: 'long', year: 'numeric' }) %></p>
                    </div>
                    <div class="prize-pool-mini">
                        <div class="ppm-row">
                            <span>🥇 5-Match Jackpot</span>
                            <strong>₹17,120</strong>
                        </div>
                        <div class="ppm-row">
                            <span>🥈 4-Match Prize</span>
                            <strong>₹14,980</strong>
                        </div>
                        <div class="ppm-row">
                            <span>🥉 3-Match Prize</span>
                            <strong>₹10,700</strong>
                        </div>
                    </div>
                    <div class="draw-countdown-mini">
                        <i class="fas fa-clock"></i>
                        Draw closes in: <strong id="miniCountdown">8d 14h 32m</strong>
                    </div>
                </div>

            </div>

            <!-- Second Row -->
            <div class="dash-grid-2">

                <!-- Charity Card -->
                <div class="dash-card">
                    <div class="dash-card-header">
                        <h3><i class="fas fa-heart"></i> My Charity</h3>
                        <a href="/charities" class="btn-card-action" style="text-decoration:none">Change Charity</a>
                    </div>
                    <% if(charity) { %>
                    <div class="charity-display">
                        <div class="charity-display-header" style="background: <%= charity.id % 3 === 0 ? 'linear-gradient(135deg, #10b981, #059669)' : (charity.id % 3 === 1 ? 'linear-gradient(135deg, #6366f1, #4f46e5)' : 'linear-gradient(135deg, #f59e0b, #d97706)') %>;">
                            <i class="fas fa-ribbon"></i>
                            <div>
                                <strong><%= charity.name %></strong>
                                <span><%= charity.category %></span>
                            </div>
                        </div>
                        <div class="charity-contribution">
                            <div class="contribution-row">
                                <span>My contribution rate</span>
                                <strong><%= user.giving_pct || 10 %>%</strong>
                            </div>
                            <div class="contribution-row">
                                <span>Monthly amount</span>
                                <strong>₹<%= (user.plan === 'yearly' ? 89.99 : 9.99) * (user.giving_pct || 10) / 100 %></strong>
                            </div>
                            <div class="contribution-row">
                                <span>Total given (all time)</span>
                                <strong class="green-text">₹<%= parseFloat(user.total_donated || 0).toFixed(2) %></strong>
                            </div>
                        </div>
                        <div class="charity-total-raised">
                            <span>Community raised for <%= charity.name %>:</span>
                            <strong>₹<%= charity.total_raised %></strong>
                        </div>
                    </div>
                    <% } else { %>
                        <p>No charity selected. <a href="/charities">Choose one</a></p>
                    <% } %>
                </div>

                <!-- Score Performance Chart -->
                <div class="dash-card">
                    <div class="dash-card-header">
                        <h3><i class="fas fa-chart-line"></i> Performance</h3>
                        <span class="dash-badge-subtle">Last 5 rounds</span>
                    </div>
                    <div class="chart-container" style="height: 220px;">
                        <canvas id="scoreChart"></canvas>
                    </div>
                </div>

            </div>
        </section>

        <!-- Scores Section -->
        <section class="dash-section" id="section-scores">
            <div class="dash-header">
                <h1 class="dash-title">My Scores</h1>
                <p class="dash-subtitle">Your latest Stableford scores — these dictate your draw numbers</p>
                <div class="dash-header-actions">
                    <button class="btn-dash-primary" onclick="openScoreModal()">
                        <i class="fas fa-plus"></i> Add New Score
                    </button>
                </div>
            </div>
            
            <div class="dash-card">
                <div class="scores-list">
                    <% if(scores && scores.length > 0) { %>
                        <% scores.forEach((s, index) => { %>
                            <div class="score-item <%= index === 0 ? 'latest' : '' %>" style="margin-bottom:15px; border-bottom:1px solid #1e293b; padding-bottom:15px;">
                                <div class="score-num-badge"><%= s.score %></div>
                                <div class="score-meta" style="flex:1;">
                                    <% let fDate = new Date(s.played_at || s.date).toLocaleDateString('en-GB') %>
                                    <span class="score-date" style="display:block; margin-bottom:5px;"><%= fDate %> · <%= s.course_name || 'Unknown Course' %></span>
                                    <span class="score-status active">✓ Logged in system</span>
                                </div>
                                <div class="score-actions">
                                    <button class="btn-score-edit" title="Edit" onclick="editScore(this, '<%= s.id %>')"><i class="fas fa-pen"></i></button>
                                    <button class="btn-score-del" title="Delete" onclick="deleteScoreBackend('<%= s.id %>')"><i class="fas fa-trash"></i></button>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="score-note" style="padding:20px;">You don't have any scores yet. Add some to enter the draw!</p>
                    <% } %>
                </div>
            </div>
        </section>

        <!-- Draws Section -->
        <section class="dash-section" id="section-draws">
            <div class="dash-header">
                <h1 class="dash-title">Draw History</h1>
                <p class="dash-subtitle">Recent automated draws</p>
            </div>
            <div class="dash-card">
                <% if(draws && draws.length > 0) { %>
                    <div class="draw-history-table-wrap">
                        <table class="draw-history-table">
                            <thead>
                                <tr><th>Date</th><th>Winning Numbers</th><th>Status</th></tr>
                            </thead>
                            <tbody>
                            <% draws.forEach(d => { %>
                                <tr>
                                    <% let fDate = new Date(d.draw_date).toLocaleDateString('en-GB') %>
                                    <td><%= fDate %></td>
                                    <td><strong><%= d.winning_numbers %></strong></td>
                                    <td><span class="status-pill <%= d.status === 'published' ? 'active' : 'pending' %>"><%= d.status %></span></td>
                                </tr>
                            <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p style="padding:20px; color:#64748b;">No draws have occurred yet.</p>
                <% } %>
            </div>
        </section>

        <!-- Winnings Section -->
        <section class="dash-section" id="section-winnings">
            <div class="dash-header">
                <h1 class="dash-title">My Winnings</h1>
                <p class="dash-subtitle">Track your matched draws and payouts</p>
            </div>
            <div class="dash-card">
                <% if(winnings && winnings.length > 0) { %>
                    <div class="draw-history-table-wrap">
                        <table class="draw-history-table">
                            <thead>
                                <tr><th>Draw Date</th><th>Matches</th><th>Prize</th><th>Status</th><th>Action</th></tr>
                            </thead>
                            <tbody>
                            <% winnings.forEach(w => { %>
                                <tr>
                                    <% let wfDate = new Date(w.draw_date).toLocaleDateString('en-GB') %>
                                    <td><%= wfDate %></td>
                                    <td><%= w.match_count %> Matches</td>
                                    <td style="font-weight:bold; color:#10b981;">₹<%= w.amount %></td>
                                    <td><span class="status-pill <%= w.status %>"><%= w.status %></span></td>
                                    <td>
                                        <% if(w.status === 'pending') { %>
                                            <% if(w.proof_image) { %>
                                                <span class="status-pill active">Under Review</span>
                                            <% } else { %>
                                                <button class="btn-card-action btn-upload-proof" onclick="openUploadModal('<%= w.id %>')">Upload Proof</button>
                                            <% } %>
                                        <% } else { %>
                                            <span style="color:#64748b; font-size:0.85rem;"><i class="fas fa-check"></i> Processed</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p style="padding:20px; color:#64748b;">You haven't won anything yet. Keep adding scores to enter the draws!</p>
                <% } %>
            </div>
        </section>

        <!-- Charity Section -->
        <section class="dash-section" id="section-charity">
            <div class="dash-header">
                <h1 class="dash-title">My Charity Selection</h1>
            </div>
            <div class="dash-card">
                <% if(charity) { %>
                    <div style="display:flex; align-items:center; gap:20px;">
                        <div style="font-size:3rem; color:#f43f5e;"><i class="fas fa-hand-holding-heart"></i></div>
                        <div>
                            <h2 style="font-size:1.5rem; margin-bottom:5px;"><%= charity.name %></h2>
                            <p style="color:#64748b; margin-bottom:15px;"><%= charity.description %></p>
                            <p><strong>Your contribution rate:</strong> <span style="background:#e0e7ff; color:#4f46e5; padding:3px 8px; border-radius:12px;"><%= user.giving_pct || 10 %>%</span></p>
                        </div>
                    </div>
                    <div style="margin-top:25px; border-top:1px solid #e2e8f0; padding-top:20px;">
                        <a href="/charities" class="btn-dash-primary" style="text-decoration:none;">Explore Other Charities</a>
                    </div>
                <% } else { %>
                    <div style="text-align:center; padding:30px;">
                        <h2 style="color:#64748b; margin-bottom:15px;">No charity selected yet.</h2>
                        <a href="/charities" class="btn-dash-primary" style="text-decoration:none;">Choose a Charity</a>
                    </div>
                <% } %>
            </div>
        </section>

        <!-- Profile & Subscription Section -->
        <section class="dash-section" id="section-subscription">
            <div class="dash-header">
                <h1 class="dash-title">Profile & Settings</h1>
                <p class="dash-subtitle">Manage your personal details and subscription tier</p>
            </div>
            
            <div class="dash-grid-2">
                <!-- Profile Settings -->
                <div class="dash-card">
                    <div class="dash-card-header">
                        <h3><i class="fas fa-user-edit"></i> My Profile</h3>
                    </div>
                    <form action="/dashboard/profile/update" method="POST">
                        <div class="form-group" style="margin-bottom:15px;">
                            <label style="color:#e2e8f0; font-size:0.85rem;">First Name</label>
                            <input type="text" name="first_name" class="form-input" style="background:#0c1222; border-color:#1e293b; color:white;" value="<%= user.first_name %>" required>
                        </div>
                        <div class="form-group" style="margin-bottom:15px;">
                            <label style="color:#e2e8f0; font-size:0.85rem;">Last Name</label>
                            <input type="text" name="last_name" class="form-input" style="background:#0c1222; border-color:#1e293b; color:white;" value="<%= user.last_name %>" required>
                        </div>
                        <div class="form-group" style="margin-bottom:25px;">
                            <label style="color:#e2e8f0; font-size:0.85rem;">Email Address</label>
                            <input type="email" name="email" class="form-input" style="background:#0c1222; border-color:#1e293b; color:white;" value="<%= user.email %>" required>
                        </div>
                        <button type="submit" class="btn-form-primary">Save Profile Changes</button>
                    </form>
                </div>

                <!-- Subscription Settings -->
                <div class="dash-card">
                    <div class="dash-card-header">
                        <h3><i class="fas fa-credit-card"></i> Subscription</h3>
                    </div>
                    <h2 style="font-size:1.25rem; margin-bottom:10px;">Current Plan: <span style="color:#10b981;"><%= (user.plan || 'monthly').toUpperCase() %></span></h2>
                    <p style="margin-bottom:15px;">Status: <span class="status-pill active">Active</span></p>
                    <p style="color:#94a3b8; line-height:1.5; margin-bottom:25px;">You are currently enrolled in the <%= user.plan || 'monthly' %> tier, which enters you automatically into all standard draws.</p>
                    <div style="display:flex; gap:15px; margin-bottom:30px;">
                        <button class="btn-dash-primary">Upgrade Plan</button>
                        <button class="btn-form-ghost">Cancel</button>
                    </div>

                    <h4 style="margin-bottom:10px; color:#e2e8f0; border-top:1px solid #1e293b; padding-top:20px;">Platform Instructions</h4>
                    <ul style="color:#94a3b8; font-size:0.85rem; padding-left:20px; line-height:1.6;">
                        <li style="margin-bottom:5px;"><strong>Golf Scores:</strong> Add scores to generate your draw numbers.</li>
                        <li style="margin-bottom:5px;"><strong>Win Verifications:</strong> If your draw matches, an <em>"Upload Proof"</em> button will dynamically appear on your <a href="#winnings" style="color:#6366f1;" onclick="showSection('winnings', event)">Winnings tab</a> so you can verify your eligibility.</li>
                    </ul>
                </div>
            </div>
        </section>

    </main>

    <!-- Score Entry Modal -->
    <div class="modal-overlay hidden" id="scoreModal">
        <div class="modal-box">
            <div class="modal-header">
                <h3>Add New Score</h3>
                <button class="modal-close" onclick="closeScoreModal()"><i class="fas fa-times"></i></button>
            </div>
            <form id="scoreForm" onsubmit="submitScoreBackend(event)">
            <div class="modal-body">
                <p class="modal-info"><i class="fas fa-info-circle"></i> Adding this score will replace your oldest score if you have 5.</p>
                <div class="form-group">
                    <label>Stableford Score (1–45)</label>
                    <div class="score-input-big">
                        <button type="button" class="score-dec" onclick="adjustScore(-1)">−</button>
                        <input type="number" name="score" id="newScore" value="35" min="1" max="45" class="score-num-input" required>
                        <button type="button" class="score-inc" onclick="adjustScore(1)">+</button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Date Played</label>
                    <input type="date" name="played_at" id="scoreDate" class="form-input" required>
                </div>
                <div class="form-group">
                    <label>Course Name (optional)</label>
                    <input type="text" name="course_name" id="courseName" class="form-input" placeholder="e.g. Royal Troon">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-form-ghost" onclick="closeScoreModal()">Cancel</button>
                <button type="submit" class="btn-form-primary">Add Score</button>
            </div>
            </form>
        </div>
    </div>

    <!-- Upload Proof Modal -->
    <div class="modal-overlay hidden" id="uploadModal">
        <div class="modal-box">
            <div class="modal-header">
                <h3>Verify Your Win</h3>
                <button class="modal-close" onclick="closeUploadModal()"><i class="fas fa-times"></i></button>
            </div>
            <form id="proofForm" enctype="multipart/form-data" method="POST" action="">
            <div class="modal-body">
                <p class="modal-info"><i class="fas fa-shield-alt"></i> Please upload a screenshot of your official golf scorecard matching the winning stableford points.</p>
                <div class="form-group" style="margin-top:20px;">
                    <label>Upload Screenshot (JPG, PNG)</label>
                    <input type="file" name="proof_image" id="proofFile" class="form-input" style="padding:10px;" accept="image/*" required>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-form-ghost" onclick="closeUploadModal()">Cancel</button>
                <button type="submit" class="btn-form-primary">Submit Verification</button>
            </div>
            </form>
        </div>
    </div>
    
    <script>
        // Custom backend hook for score submission to override dashboard.js
        async function submitScoreBackend(e) {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            try {
                const res = await fetch('/dashboard/scores/add', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify(data)
                });
                if(res.ok) {
                    window.location.reload();
                } else {
                    alert("Failed to add score");
                }
            } catch(e) {
                console.error(e);
            }
        }

        async function deleteScoreBackend(id) {
            if(confirm('Are you sure you want to delete this score?')) {
                try {
                    const res = await fetch('/dashboard/scores/delete/' + id, { method: 'POST' });
                    if(res.ok) window.location.reload();
                } catch(e) { console.error(e); }
            }
        }
    </script>

<%- include('partials/footer') %>
